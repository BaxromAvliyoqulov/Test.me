rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if request is by the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Helper to check if user is admin
    function isAdmin() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.isAdmin == true;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow create: if (isOwner(userId) && !('isAdmin' in request.resource.data)) || isAdmin();
      allow delete: if isOwner(userId) || isAdmin();
      allow update: if isAdmin() || 
        (isOwner(userId) && (!request.resource.data.diff(resource.data).affectedKeys().hasAny(['isAdmin', 'adminRole']))) ||
        (isAuthenticated() && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['points']) && request.resource.data.points == resource.data.points + 50);

      // User transactions sub-collection (test rewards & purchases)
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId) || (isAuthenticated() && request.resource.data.points == 50);
        allow update, delete: if false;
      }

      // Referral activity log sub-collection
      match /referral-logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // User Inventory sub-collection
      match /inventory/{itemId} {
        allow read: if isOwner(userId);
        allow create, delete: if isOwner(userId);
        allow update: if false;
      }

      // User Goals sub-collection (For Edit Profile)
      match /goals/{goalId} {
        allow read, write: if isOwner(userId);
      }

      // User Notifications sub-collection
      match /notifications/{notificationId} {
        allow read, write: if isOwner(userId);
      }
    }

    // Subjects and nested collections read-only for authenticated users
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
      
      match /levels/{levelId} {
        allow read: if isAuthenticated();
        allow write: if isAuthenticated();
        
        match /tests/{testId} {
          allow read: if isAuthenticated();
          allow write: if isAuthenticated();
        }
      }
    }

    // Special Tests rules
    match /special_tests/{testId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }

    // Test Sessions rules
    match /testSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // Results rules
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // AI Tests rules
    match /ai_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // Certificates rules - users can read their own, written by testPage client-side
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // --- TP Coin Economy & Shop Rules ---
    match /shop_items/{itemId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated(); // Admin will write, simplified for now
    }
    match /shop_boxes/{boxId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated();
    }
    
    // --- Friends & Chat Rules ---
    match /chats/{chatId} {
      allow read: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      allow create: if isAuthenticated() && (request.auth.uid in request.resource.data.participants);
      allow update: if isAuthenticated() && (request.auth.uid in resource.data.participants);
      
      match /messages/{messageId} {
        allow read: if isAuthenticated(); 
        allow create: if isAuthenticated() && request.resource.data.senderId == request.auth.uid;
      }
    }
    
    match /friend_requests/{requestId} {
      allow read: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.uid;
      allow update, delete: if isAuthenticated() && (request.auth.uid == resource.data.from || request.auth.uid == resource.data.to);
    }
  }
}
