rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check if user is authenticated
    function isAuthenticated() {
      return request.auth != null;
    }

    // Helper to check if request is by the owner
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    // Users collection rules
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isOwner(userId);

      // User transactions sub-collection (test rewards & purchases)
      match /transactions/{txId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }

      // Referral activity log sub-collection
      match /referral-logs/{logId} {
        allow read: if isOwner(userId);
        allow create: if isOwner(userId);
        allow update, delete: if false;
      }
    }

    // Subjects and nested collections read-only for authenticated users
    match /subjects/{subjectId} {
      allow read: if isAuthenticated();
      allow write: if false;
      
      match /levels/{levelId} {
        allow read: if isAuthenticated();
        allow write: if false;
        
        match /tests/{testId} {
          allow read: if isAuthenticated();
          allow write: if false;
        }
      }
    }

    // Test Sessions rules
    match /testSessions/{sessionId} {
      allow read, write: if isAuthenticated();
    }

    // Results rules
    match /results/{resultId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // AI Tests rules
    match /ai_tests/{testId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.creatorId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.creatorId == request.auth.uid;
    }

    // Certificates rules - users can read their own, written by testPage client-side
    match /certificates/{certId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }
  }
}
